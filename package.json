{
  "name": "jiwnchoi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm datagen && concurrently \"next dev \" \"pnpm datagen --watch\"",
    "build": "pnpm datagen && next build ",
    "typecheck": "node ./node_modules/typescript-next/bin/tsc --noEmit",
    "start": "next start",
    "prestart": "pnpm datagen",
    "lint": "next lint",
    "format": "prettier --write .",
    "postbuild": "pagefind --site .next/server/app --output-path public/_pagefind",
    "prepare": "husky",
    "datagen": "node generate-data.js -i ./data -o ./data -a data-accessor.ts -x"
  },
  "dependencies": {
    "@giscus/react": "^3.1.0",
    "@hugeicons/core-free-icons": "^4.2.2",
    "@hugeicons/react": "^1.1.9",
    "@next/third-parties": "^16.2.10",
    "@vercel/analytics": "^2.0.1",
    "@vercel/og": "^0.11.1",
    "@vercel/speed-insights": "^2.0.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "katex": "^0.17.0",
    "mime-types": "^3.0.2",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "next-view-transitions": "^0.3.5",
    "nextra": "^4.6.1",
    "nextra-theme-blog": "^4.6.1",
    "react": "^19.2.7",
    "react-devicons": "^2.16.2",
    "react-dom": "^19.2.7",
    "react-icons": "^5.7.0",
    "sharp": "^0.35.3",
    "tailwind-merge": "^3.6.0",
    "theme-change": "^3.0.4",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/typography": "^0.5.20",
    "@types/js-yaml": "^4.0.9",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "chokidar": "^5.0.0",
    "concurrently": "^10.0.3",
    "daisyui": "^5.6.18",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.10",
    "husky": "^9.1.7",
    "js-yaml": "^5.2.1",
    "lint-staged": "^17.0.8",
    "pagefind": "^1.5.2",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "quicktype-core": "^24.0.2",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "typescript-next": "npm:typescript@^7.0.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,md,mdx}": [
      "prettier --write"
    ]
  }
}
